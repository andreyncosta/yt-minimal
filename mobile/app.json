{
  "expo": {
    "name": "YT Minimal",
    "slug": "yt-minimal",
    "scheme": "ytminimal",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": false,
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-router"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.araujocostamkt.ytminimal"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.araujocostamkt.ytminimal"
    }
  }
}
