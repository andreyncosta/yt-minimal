# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT session tokens — generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_openssl_rand_hex_32_output

# Fernet encryption for refresh tokens — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace_with_fernet_generate_key_output

# Comma-separated list of allowed CORS origins
# Examples: exp://192.168.1.100:8081,ytminimal://
ALLOWED_ORIGINS=exp://192.168.x.x:8081,ytminimal://

# URL scheme the backend redirects to after /auth/callback (must match app.json "scheme")
MOBILE_REDIRECT_SCHEME=ytminimal

# SQLite database path for encrypted token store (relative to working directory)
# Defaults to tokens.db if unset. Set to an absolute path in production.
TOKEN_DB_PATH=tokens.db
